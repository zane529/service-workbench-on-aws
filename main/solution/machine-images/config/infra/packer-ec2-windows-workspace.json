{
  "variables": {
    "aws_access_key": "",
    "aws_secret_key": "",
    "vpcId": "",
    "subnetId": "",
    "awsProfile": "",
    "awsRegion": "",
    "amiName": ""
  },
  "builders": [
    {
      "type": "amazon-ebs",
      "profile": "{{user `awsProfile`}}",
      "access_key": "{{user `aws_access_key`}}",
      "secret_key": "{{user `aws_secret_key`}}",
      "region": "{{user `awsRegion`}}",
      "vpc_id": "{{user `vpcId`}}",
      "subnet_id": "{{user `subnetId`}}",
      "source_ami_filter": {
        "filters": {
          "virtualization-type": "hvm",
          "name": "Windows_Server-2022-English-Full-Base-*",
          "root-device-type": "ebs"
        },
        "owners": [
          "amazon"
        ],
        "most_recent": true
      },
      "instance_type": "c6i.large",
      "communicator": "none",
      "ami_name": "{{user `ec2WindowsAmiPrefix`}}-{{timestamp}}"
    }
  ],
  "provisioners": [
    {
      "type": "powershell",
      "inline": [
        "$ConfigPath = 'C:\\ProgramData\\Amazon\\EC2Launch\\config\\agent-config.yml'",
        "$Lines = Get-Content $ConfigPath",
        "$InsertIndex = ($Lines | Select-String -Pattern '^config:' | Select-Object -First 1).LineNumber",
        "$NewLines = @()",
        "for ($i = 0; $i -lt $Lines.Length; $i++) {",
        "  $NewLines += $Lines[$i]",
        "  if ($i -eq $InsertIndex) {",
        "    $NewLines += '  user_data:'",
        "    $NewLines += '    enabled: true'",
        "  }",
        "}",
        "Set-Content $ConfigPath $NewLines",
        "Restart-Service EC2Launch"
      ]
    },
    {
      "type": "powershell",
      "inline": [
        "C:\\Program Files\\Amazon\\EC2Launch\\ec2launch.exe sysprep -s"
      ]
    }
  ]
}